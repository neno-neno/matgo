# ==========================================
# MatGo API - Environment Variables
# ==========================================

# Ambiente (development, staging, production)
MTD_ENVIRONMENT=production

# CORS: Quais domínios podem acessar a API? (Inclua o domínio onde o frontend Next.js for hospedado, ex: Vercel)
# Pode ser uma lista formatada em JSON
MTD_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","https://seu-projeto-frontend.vercel.app"]

# Regex para CORS (Opcional, útil para subdomínios Vercel dinâmicos de PRs)
MTD_CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Banco de dados SUPABASE
# Para conectar ao PostgreSQL do Supabase via psycopg, cole sua string Connection Pooler aqui:
# Exemplo: postgresql://postgres.[PROJETO]:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
MTD_DATABASE_URL=postgresql://postgres.[ID_PROJETO]:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# SQLite fallback (Em produção com Supabase, essa variável será ignorada)
MTD_DATABASE_PATH=data/matematica_todo_dia.db

# Senha mestra (usada para criação pontual de professores)
MTD_MASTER_ACCESS_CODE=MASTER-MAT-2026
