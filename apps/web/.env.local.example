# ==========================================
# MatGo Web (Next.js) - Environment Variables
# ==========================================

# URL Pública da API (Acessada pelo navegador/cliente)
# Mude para a URL do seu backend no Render/Railway (ex: https://matgo-api.onrender.com)
NEXT_PUBLIC_API_URL=https://sua-api.onrender.com

# URL Interna da API (Acessada pelo servidor Next.js durante SSR)
# Em produção, geralmente é a mesma da NEXT_PUBLIC_API_URL
API_URL=https://sua-api.onrender.com
